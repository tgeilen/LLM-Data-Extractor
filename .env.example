# Azure OCR Configuration
AZURE_OCR_API_KEY=your_azure_ocr_api_key_here
AZURE_OCR_ENDPOINT=https://your-endpoint.eastus.models.ai.azure.com/v1/ocr

# LLM Provider API Keys
DEEPSEEK_API_TOKEN=your_deepseek_api_token_here
GEMINI_API_KEY=your_gemini_api_key_here


# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/master_thesis_db

# Optional: Custom settings
MAX_CHUNK_SIZE=15000
DEFAULT_TEMPERATURE=0.3
BATCH_SIZE=10
